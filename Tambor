const int NUM_LEDS = 8;
const int leds[NUM_LEDS] = {2, 3, 4, 5, 10, 11, 12, 13};

const int VELOCIDAD = 80; // ms por paso — bajá para ir más rápido

int posicion = 0;

void setup() {
  for (int i = 0; i < NUM_LEDS; i++) {
    pinMode(leds[i], OUTPUT);
  }
}

void loop() {
  digitalWrite(leds[posicion], HIGH);
  delay(VELOCIDAD);
  digitalWrite(leds[posicion], LOW);

  posicion = (posicion + 1) % NUM_LEDS;
}
